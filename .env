# Set to false to talk to the real PULSE backend (uvicorn api:app --port 8000).
# Keep it true only when api.py isn't running / you just want to preview the UI.
VITE_USE_MOCK=true
VITE_API_BASE_URL=http://localhost:8000

# Optional: point this at a remote LLM endpoint for the analyst Copilot panel.
# Leave blank to use the built-in local heuristic provider.
VITE_LLM_ENDPOINT=

