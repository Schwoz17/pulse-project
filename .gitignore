cat > .gitignore << 'EOF'
__pycache__/
*.pyc
.venv/
venv/
.env
api.log

# Generated by synthetic_data.py
raw_sessions.json
user_baselines.json

# Generated by synthetic_transactions.py
daily_balances.json
balance_checks.json
finance_baselines.json

# Generated by features.py / risk_model.py
features.csv
risk_scores.csv

# Generated by running nudge_agent.py / risk_arbiter.py as scripts
nudges.json
arbitration_results.json
EOF